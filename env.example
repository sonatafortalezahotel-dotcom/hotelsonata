# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hotel_sonata

# Stripe (opcional - para pagamentos)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Mercado Pago (alternativa ao Stripe)
# MERCADOPAGO_ACCESS_TOKEN=TEST-...
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-...

# Upload (Vercel Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# NextAuth (se usar autenticação)
NEXTAUTH_SECRET=your-secret-key
NEXTAUTH_URL=http://localhost:3000

# SMTP (Locaweb / email-ssl.com.br — Hotel Sonata)
SMTP_HOST=email-ssl.com.br
SMTP_PORT=465
SMTP_USER=naoresponda@hotelsonata.com.br
SMTP_PASSWORD=
SMTP_FROM_EMAIL=naoresponda@hotelsonata.com.br
SMTP_FROM_NAME=Hotel Sonata

# Destinatários dos formulários
RH_EMAIL=vagas@hotelsonata.com.br
EVENTOS_EMAIL=reservas@sonatadeiracema.com.br
CONTACT_EMAIL=reservas@sonatadeiracema.com.br
