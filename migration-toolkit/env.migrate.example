# Renomear cópia para .env.migrate.local — NUNCA fazer commit.

# --- Neon: antigo (só source do dump) ---
MIGRATE_NEON_SOURCE_URL=postgresql://user:pass@ep-SEU-PROJ-ANTIGO.us-east-1.aws.neon.tech/db?sslmode=require

# --- Neon: novo (app + destino) ---
DATABASE_URL=postgresql://user:pass@ep-SEU-PROJ-NOVO-pooler.../db?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-SEU-PROJ-NOVO.../db?sslmode=require
# MIGRATE_NEON_TARGET_URL=  (opcional; vazio = usa UNPOOLED/URL acima)
# MIGRATE_NEON_CLEAN=1  (cuidado: apaga no destino objectos com mesmo nome no restore)

# --- Vercel Blob ---
OLD_BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
NEW_BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# BLOB_MIGRATE_PUT_ACCESS=public   ou  private
# OLD_BLOB_LIST_PREFIX=pasta/   (opcional, filtrar list)

# --- Replace no Postgres (prefixos do URL, sem / no fim) ---
BLOB_PUBLIC_ORIGIN_OLD=
BLOB_PUBLIC_ORIGIN_NEW=

