# =============================================================================
# MIGRAÇÃO — colocar o mesmo conteúdo no ficheiro .env.migrate.local (ignorado pelo Git).
# Se estiveres a guardar segredos AQUI, não faças "git add" a este ficheiro.
# =============================================================================
#
# SCRIPTS:   migrate:neon-dump  |  migrate:blob-copy  |  migrate:blob-origins  |  migrate:blob-urls-db
# -----------------------------------------------------------------------------

# ——— Neon: ANTIGO → SÓ FONTE DO DUMP (unpooled / direct, sem "pooler" no host) ———
MIGRATE_NEON_SOURCE_URL=postgresql://neondb_owner:npg_6rWBqDybm9Rv@ep-purple-silence-a4zi085p.us-east-1.aws.neon.tech/neondb?sslmode=require

# ——— Neon: NOVO → APLICAÇÃO E DESTINO DO pg_restore (MIGRATE_NEON_TARGET_URL vazio = usa os dois abaixo) ———
DATABASE_URL=postgresql://neondb_owner:npg_MmPJ6kOqd5eo@ep-withered-frog-a4iyokmk-pooler.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:npg_MmPJ6kOqd5eo@ep-withered-frog-a4iyokmk.us-east-1.aws.neon.tech/neondb?sslmode=require
# MIGRATE_NEON_TARGET_URL=   (opcional; força o destino explícito)
# MIGRATE_NEON_CLEAN=1       (opcional; no restore apaga no destino objectos com o mesmo nome)

# ——— Vercel Blob: LOJA ANTIGA (origem) E NOVA (destino) ———
OLD_BLOB_READ_WRITE_TOKEN=vercel_blob_rw_onRovwlwOVzsytDF_DlWaNhQlr0UAcT1etFBgvhyVK6mxLt
NEW_BLOB_READ_WRITE_TOKEN=vercel_blob_rw_9gWMehEuUcD5qz3O_Yzw6o6nQBBmgVg0n6gj6alyIzGop5W
BLOB_MIGRATE_PUT_ACCESS=private

# ——— Origens (prefixo do URL, sem / no fim) — gera com: npm run migrate:blob-origins ———
BLOB_PUBLIC_ORIGIN_OLD=https://onrovwlwovzsytdf.public.blob.vercel-storage.com
BLOB_PUBLIC_ORIGIN_NEW=https://9gwmeheuucd5qz3o.private.blob.vercel-storage.com

# OLD_BLOB_LIST_PREFIX=      (opcional, ex. hotel-sonata/)
# DRY_RUN=1                  (só simular migrate:blob-urls-db)

